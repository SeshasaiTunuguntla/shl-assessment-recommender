# LLM API Keys (choose one or more)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Or use free alternatives
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# Model selection
LLM_PROVIDER=openai  # Options: openai, anthropic, groq, gemini
LLM_MODEL=gpt-4-turbo-preview  # Or: claude-3-sonnet, mixtral-8x7b, gemini-pro

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
TIMEOUT_SECONDS=30
